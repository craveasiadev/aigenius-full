# Local runtime config — never commit secrets
.env
.env.local
.env.*.local
**/.env
**/.env.local
!**/.env.example
!**/.env.production.example
# Root runtime env file (carries live secrets — never commit)
/env

# Build / vendor artifacts (shouldn't be in repo — they're rebuilt in Docker)
frontend/node_modules
frontend/dist
frontend/android
frontend/test-results
backend/vendor
backend/node_modules
backend/storage/logs/*.log
backend/storage/framework/cache/data
backend/storage/framework/sessions
backend/storage/framework/views
backend/bootstrap/cache/*.php

# Secrets / private keys — never commit
qbot
qbot.ppk
*.ppk
*.pem

# Docker
*.pid

# IDE / OS
.idea
.vscode
.DS_Store
Thumbs.db

# Local-only docker overrides (never deploy to production)
docker-compose.override.yml
docker/web-local/
