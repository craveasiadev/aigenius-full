APP_NAME=Wonderstar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
SUPERADMIN_LOGIN_DEBUG=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artventure
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

WPAY_DEFAULT_APP_SOURCE=wonderstar
SUPERADMIN_WPAY_APP_SOURCE=artventure

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=array

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MailerSend Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="Wonderstar"

# Supabase Configuration (for user management)
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Frontend URL (for password reset links and redirects)
# For local development: http://localhost:5173
# For production: https://your-frontend-domain
FRONTEND_URL=http://localhost:5173

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# FiuuPay Configuration (request from Fiuu support)
FIUU_MERCHANT_ID=
FIUU_VERIFY_KEY=
FIUU_SECRET_KEY=
FIUU_PAYMENT_URL=

# Payment Gateway Runtime Mode
# prod = Fiuu
# sandbox = ToyyibPay
PAYMENT_GATEWAY_MODE=prod

# ToyyibPay (Sandbox/Dev)
TOYYIBPAY_SECRET=
TOYYIBPAY_CATEGORY=
TOYYIBPAY_URL=https://dev.toyyibpay.com

# CORS Settings
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost

# iSMS Configuration
ISMS_USERNAME=
ISMS_PASSWORD=
ISMS_SENDER_ID=
