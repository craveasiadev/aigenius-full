# Production Environment
# This file is automatically used when running: npm run build

# Laravel API Backend - Production URL
VITE_API_URL=https://app.aigenius.com.my

# Assets URL for images served from Laravel backend
VITE_ASSETS_URL=https://app.aigenius.com.my

# OpenAI API key should NOT be in frontend - use backend API instead
# VITE_OPENAI_API_KEY is intentionally removed for security

# Base path for production hosting (use '/' for root or '/subdir/')
VITE_BASE=/
