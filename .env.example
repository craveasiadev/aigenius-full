# =====================================================================
# Aigenius-Full — copy to `.env` and edit before `docker compose up`
# =====================================================================
# Anything you set here is consumed by docker-compose.yml and passed
# through to the Laravel containers at runtime. Laravel's own .env
# (inside backend/) still ships with the image but values here win.

# ---- Web -------------------------------------------------------------
# HTTP_PORT is what nginx binds on the *host*. Behind a reverse proxy on
# the VPS, set this to an unused port (e.g. 8082) and point your proxy at
# 127.0.0.1:8082. Locally you can leave it on 80.
HTTP_PORT=80
HTTP_BIND=0.0.0.0          # use 127.0.0.1 on a VPS so nginx isn't directly exposed

APP_NAME=Aigenius
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
# When behind a TLS-terminating reverse proxy, set TRUSTED_PROXIES=*
# so Laravel honors X-Forwarded-Proto and emits https:// URLs.
TRUSTED_PROXIES=
APP_TIMEZONE=Asia/Kuala_Lumpur
LOG_LEVEL=warning

# ---- Database --------------------------------------------------------
DB_ROOT_PASSWORD=change-me-root
DB_DATABASE=aigenius
DB_USERNAME=aigenius
DB_PASSWORD=change-me-app

# ---- Session / CORS --------------------------------------------------
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=localhost

# ---- Mail (MailerSend by default) ------------------------------------
MAIL_MAILER=mailersend
MAILERSEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@aigenius.com.my
MAIL_FROM_NAME=Aigenius

# ---- OpenAI ----------------------------------------------------------
OPENAI_API_KEY=

# ---- Supabase (user mgmt) --------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Payments — Fiuu --------------------------------------------------
FIUU_MERCHANT_ID=
FIUU_VERIFY_KEY=
FIUU_SECRET_KEY=
FIUU_PAYMENT_URL=

# ---- Payments — ToyyibPay --------------------------------------------
TOYYIBPAY_SECRET=
TOYYIBPAY_CATEGORY=
TOYYIBPAY_URL=

# ---- SMS — iSMS ------------------------------------------------------
ISMS_USERNAME=
ISMS_PASSWORD=
ISMS_SENDER_ID=

# ---- Frontend build args (Vite) --------------------------------------
# Leave VITE_API_URL=/api so the SPA hits the same origin via nginx
# (avoids CORS headaches in production).
VITE_API_URL=/api
VITE_ASSETS_URL=
VITE_BASE=/

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
